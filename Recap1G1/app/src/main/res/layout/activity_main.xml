<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/lblDescriptionWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="This app is to help you keep track of\nwhat you have packed for an\nupcoming trip."
        android:textAlignment="center"
        android:textSize="24sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.481"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.37" />

    <TextView
        android:id="@+id/lblHeadingWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Packing Assistant"
        android:textSize="34sp"
        android:textStyle="italic"
        tools:layout_editor_absoluteX="73dp"
        tools:layout_editor_absoluteY="33dp" />

    <Button
        android:id="@+id/btnBeginWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#4CAF50"
        android:text="Begin"
        tools:layout_editor_absoluteX="160dp"
        tools:layout_editor_absoluteY="464dp" />

    <Button
        android:id="@+id/btnCloseWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#F44336"
        android:text="Close"
        tools:layout_editor_absoluteX="160dp"
        tools:layout_editor_absoluteY="546dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
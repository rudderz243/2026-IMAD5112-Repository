<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Screen3">

    <TextView
        android:id="@+id/lblHeadingS3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Itinerary"
        android:textSize="34sp"
        android:textStyle="italic"
        tools:layout_editor_absoluteX="145dp"
        tools:layout_editor_absoluteY="74dp" />

    <TextView
        android:id="@+id/lblOutputS3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Items will appear here"
        android:textSize="24sp"
        tools:layout_editor_absoluteX="88dp"
        tools:layout_editor_absoluteY="304dp" />

    <Button
        android:id="@+id/btnShowS3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#009688"
        android:text="Show All Items"
        tools:layout_editor_absoluteX="134dp"
        tools:layout_editor_absoluteY="464dp" />

    <Button
        android:id="@+id/btnCloseS3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#F44336"
        android:text="Close App"
        tools:layout_editor_absoluteX="149dp"
        tools:layout_editor_absoluteY="535dp" />
</androidx.constraintlayout.widget.ConstraintLayout>
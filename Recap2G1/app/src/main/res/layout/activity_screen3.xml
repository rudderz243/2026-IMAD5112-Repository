<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Screen3">

    <TextView
        android:id="@+id/lblHeadingS3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mark Information"
        android:textSize="34sp"
        android:textStyle="italic"
        tools:layout_editor_absoluteX="79dp"
        tools:layout_editor_absoluteY="46dp" />

    <TextView
        android:id="@+id/lblOutputS3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Output goes here"
        android:textSize="24sp"
        tools:layout_editor_absoluteX="114dp"
        tools:layout_editor_absoluteY="229dp" />

    <Button
        android:id="@+id/btnAllS3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#2196F3"
        android:text="View All Marks"
        tools:layout_editor_absoluteX="134dp"
        tools:layout_editor_absoluteY="423dp" />

    <Button
        android:id="@+id/btnAverageS3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#2196F3"
        android:text="View Average Mark"
        tools:layout_editor_absoluteX="120dp"
        tools:layout_editor_absoluteY="479dp" />

    <Button
        android:id="@+id/btnMaxMinS3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#2196F3"
        android:text="View Highest and Lowest"
        tools:layout_editor_absoluteX="101dp"
        tools:layout_editor_absoluteY="534dp" />

    <Button
        android:id="@+id/btnCloseS3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#F44336"
        android:text="Close"
        tools:layout_editor_absoluteX="161dp"
        tools:layout_editor_absoluteY="615dp" />
</androidx.constraintlayout.widget.ConstraintLayout>